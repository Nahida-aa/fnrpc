{
  "name": "@fnrpc/client",
  "version": "0.1.0",
  "description": "fnRPC client — transport-agnostic RPC client with Proxy-based typed API",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.ts --clean-dir && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rolldown": "^1.0.0",
    "typescript": "^7"
  }
}

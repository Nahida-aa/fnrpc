{
  "name": "@fnrpc/client",
  "version": "0.3.1",
  "description": "fnRPC client — transport-agnostic RPC client with Proxy-based typed API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nahida-aa/fnrpc.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.ts --clean-dir && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test:typecheck": "tsc -p tsconfig.test.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "rolldown": "^1.0.0",
    "typescript": "^7"
  }
}

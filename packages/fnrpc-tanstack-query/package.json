{
  "name": "@fnrpc/tanstack-query",
  "version": "0.3.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nahida-aa/fnrpc.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "scripts": {
    "build": "rolldown -c rolldown.config.ts --clean-dir && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/query-core": "^5.101.2",
    "@fnrpc/client": "workspace:*"
  },
  "devDependencies": {
    "rolldown": "^1.0.0",
    "typescript": "^7"
  }
}
